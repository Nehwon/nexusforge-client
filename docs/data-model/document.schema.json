{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusforge.app/schemas/document.schema.json",
  "title": "Document",
  "type": "object",
  "required": ["id", "type", "title", "ownerUserId", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Identifiant unique du document (UUID)."
    },

    "type": {
      "type": "string",
      "enum": ["image", "pdf", "text", "handout", "characterLink", "itemLink", "other"],
      "description": "Type de contenu du document."
    },

    "title": {
      "type": "string",
      "description": "Titre ou nom du document."
    },

    "description": {
      "type": "string",
      "description": "Description facultative du document."
    },

    "ownerUserId": {
      "type": "string",
      "description": "Utilisateur qui possčde le document (créateur ou importateur)."
    },

    "createdByUserId": {
      "type": ["string", "null"],
      "description": "Utilisateur qui a créé/importé le document."
    },

    "fileUrl": {
      "type": ["string", "null"],
      "description": "URL vers le fichier (image/PDF) hébergé."
    },

    "thumbnailUrl": {
      "type": ["string", "null"],
      "description": "URL d'une miniature."
    },

    "linkedEntity": {
      "type": ["object", "null"],
      "description": "Lien vers une entité interne (fiches, objets, etc.).",
      "properties": {
        "entityType": {
          "type": "string",
          "enum": ["character", "item", "note", "other"]
        },
        "entityId": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "tags": {
      "type": "array",
      "description": "Tags de classification (indice, carte, PNJ, etc.).",
      "items": { "type": "string" }
    },

    "visibility": {
      "type": "object",
      "description": "Visibilité globale (hors contexte de session).",
      "properties": {
        "isPublic": {
          "type": "boolean",
          "default": false
        },
        "sharedWithUserIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },

    "createdAt": {
      "type": "string",
      "format": "date-time"
    },

    "updatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },

    "sync": {
      "type": "object",
      "description": "Infos de synchronisation offline-first.",
      "properties": {
        "lastSyncedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "lastModifiedBy": {
          "type": ["string", "null"],
          "description": "Dernier utilisateur ayant modifié le document."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
