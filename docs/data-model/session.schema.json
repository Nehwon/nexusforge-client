{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusforge.app/schemas/session.schema.json",
  "title": "Session",
  "type": "object",
  "required": ["id", "systemId", "name", "createdAt", "updatedAt", "state"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Identifiant unique de la session (UUID)."
    },
    "systemId": {
      "type": "string",
      "description": "Référence au système de jeu utilisé pour cette session."
    },

    "campaignId": {
      "type": ["string", "null"],
      "description": "Référence optionnelle à une campagne si le modèle prévoit des campagnes."
    },

    "name": {
      "type": "string",
      "description": "Nom de la session (ex: 'Session 3 - La Tour')."
    },
    "description": {
      "type": "string",
      "description": "Description ou résumé de la session."
    },

    "gmUserId": {
      "type": "string",
      "description": "Identifiant de l'utilisateur MJ de cette session."
    },

    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },

    "state": {
      "type": "string",
      "enum": ["planned", "running", "paused", "finished"],
      "description": "État courant de la session."
    },

    "settings": {
      "type": "object",
      "description": "Paramètres spécifiques à la session.",
      "properties": {
        "allowPlayerToEditCharacterOffline": {
          "type": "boolean",
          "default": true,
          "description": "Autoriser les joueurs à éditer leurs fiches hors session."
        },
        "allowPlayerToPlayerChat": {
          "type": "boolean",
          "default": true,
          "description": "Autoriser les communications entre joueurs."
        },
        "allowPlayerToPlayerDocuments": {
          "type": "boolean",
          "default": true,
          "description": "Autoriser les transferts de documents entre joueurs."
        },
        "silenceMode": {
          "type": "string",
          "enum": ["off", "noGlobal", "playersToPlayersBlocked", "full"],
          "default": "off",
          "description": "Mode de blocage des communications (défini par le MJ)."
        }
      },
      "additionalProperties": true
    },

    "participants": {
      "type": "array",
      "description": "Liste des participants à la session.",
      "items": {
        "type": "object",
        "required": ["userId", "role"],
        "properties": {
          "userId": {
            "type": "string",
            "description": "Identifiant de l'utilisateur."
          },
          "role": {
            "type": "string",
            "enum": ["gm", "player", "observer"],
            "description": "Rôle global dans la session."
          },
          "characterId": {
            "type": ["string", "null"],
            "description": "Fiche de personnage liée pour un joueur (PJ principal)."
          },
          "isConnected": {
            "type": "boolean",
            "default": false
          },
          "lastSeenAt": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },

    "screens": {
      "type": "array",
      "description": "Instances d'écrans (MJ, battlemap, infos joueurs, etc.) liés à cette session.",
      "items": {
        "type": "object",
        "required": ["id", "type", "ownerUserId"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant de l'écran (instance côté client)."
          },
          "type": {
            "type": "string",
            "enum": ["gm", "battlemap", "playerDashboard"],
            "description": "Type d'écran."
          },
          "ownerUserId": {
            "type": "string",
            "description": "User qui contrôle cet écran (souvent le MJ)."
          },
          "displayName": {
            "type": "string",
            "description": "Nom affiché de l'écran (ex: 'Battlemap TV')."
          },
          "activeView": {
            "type": "string",
            "description": "Vue/onglet actuellement affiché sur cet écran (ex: 'map:forest', 'doc:handout1')."
          },
          "layoutConfig": {
            "type": ["object", "null"],
            "description": "Configuration de layout spécifique (pour le dashboard MJ par exemple).",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },

    "initiative": {
      "type": "object",
      "description": "État de l'ordre d'initiative de la session.",
      "properties": {
        "round": {
          "type": "number",
          "default": 1
        },
        "turnIndex": {
          "type": "number",
          "default": 0,
          "description": "Index du tour courant dans la liste entries."
        },
        "entries": {
          "type": "array",
          "description": "Entrées d'initiative (PJ, PNJ, autres entités).",
          "items": {
            "type": "object",
            "required": ["id", "type", "initiative"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Identifiant unique de l'entrée d'initiative."
              },
              "type": {
                "type": "string",
                "enum": ["character", "group", "other"],
                "description": "Type d'entrée (PJ/PNJ, groupe, autre)."
              },
              "characterId": {
                "type": ["string", "null"],
                "description": "Lien vers une fiche (PJ/PNJ) si applicable."
              },
              "name": {
                "type": "string",
                "description": "Nom affiché si pas de lien vers character."
              },
              "initiative": {
                "type": "number",
                "description": "Valeur d'initiative pour le tri."
              },
              "isActive": {
                "type": "boolean",
                "default": true
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "groups": {
      "type": "array",
      "description": "Groupes de communication et de jeu (ex: groupes de PJ séparés).",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant unique du groupe."
          },
          "name": {
            "type": "string",
            "description": "Nom du groupe (ex: 'Groupe A', 'Grotte')."
          },
          "description": {
            "type": "string",
            "description": "Description du groupe."
          },
          "memberUserIds": {
            "type": "array",
            "description": "Liste des userIds des joueurs dans ce groupe.",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },

    "communication": {
      "type": "object",
      "description": "État de la communication (paramètres, derniers messages, etc.).",
      "properties": {
        "lastMessageAt": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Horodatage du dernier message reçu dans la session."
        },
        "channels": {
          "type": "array",
          "description": "Canaux logiques (global, groupes, MP).",
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Identifiant du canal."
              },
              "type": {
                "type": "string",
                "enum": ["global", "group", "direct"],
                "description": "Type de canal."
              },
              "name": {
                "type": "string",
                "description": "Nom affiché du canal."
              },
              "groupId": {
                "type": ["string", "null"],
                "description": "Référence à un groupe si type = 'group'."
              },
              "memberUserIds": {
                "type": "array",
                "description": "Participants à ce canal (pour 'direct' ou 'group').",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },

    "documents": {
      "type": "array",
      "description": "Documents liés à la session (handouts, images, etc.) avec métadonnées de partage.",
      "items": {
        "type": "object",
        "required": ["id", "title", "type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant du document dans le contexte de la session."
          },
          "type": {
            "type": "string",
            "enum": ["image", "pdf", "note", "character", "item", "other"]
          },
          "title": {
            "type": "string",
            "description": "Titre du document."
          },
          "sourceId": {
            "type": ["string", "null"],
            "description": "Référence au document/fichier/entité sous-jacent (dans une autre collection)."
          },
          "ownerUserId": {
            "type": ["string", "null"],
            "description": "User qui a importé ce document dans la session (MJ ou joueur)."
          },
          "sharedWithUserIds": {
            "type": "array",
            "description": "Liste des users avec qui ce doc est explicitement partagé (en plus du MJ).",
            "items": { "type": "string" }
          },
          "isSharedWithAllPlayers": {
            "type": "boolean",
            "default": false
          },
          "lastSharedAt": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Dernière fois où le doc a été partagé/affiché."
          }
        },
        "additionalProperties": false
      }
    },

    "log": {
      "type": "array",
      "description": "Historique simplifié des événements importants de la session.",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "type"],
        "properties": {
          "id": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string",
            "description": "Type d'événement (ex: 'roll', 'note_added', 'doc_shared', etc.)."
          },
          "data": {
            "type": "object",
            "description": "Payload associé à l'événement.",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },

    "sync": {
      "type": "object",
      "description": "Infos de synchronisation pour offline-first.",
      "properties": {
        "lastSyncedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "lastModifiedBy": {
          "type": ["string", "null"],
          "description": "Dernier user à avoir modifié la session (souvent le MJ)."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
