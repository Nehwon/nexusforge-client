{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusforge.app/schemas/user.schema.json",
  "title": "User",
  "type": "object",
  "required": ["id", "email", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Identifiant unique de l'utilisateur (UUID)."
    },

    "email": {
      "type": "string",
      "format": "email",
      "description": "Adresse email de connexion."
    },

    "username": {
      "type": "string",
      "description": "Nom d'utilisateur affiché."
    },

    "displayName": {
      "type": "string",
      "description": "Nom affiché (peut différer de username)."
    },

    "avatarUrl": {
      "type": ["string", "null"],
      "description": "URL d'un avatar."
    },

    "passwordHash": {
      "type": "string",
      "description": "Hash du mot de passe (jamais le mot de passe en clair)."
    },

    "isEmailVerified": {
      "type": "boolean",
      "default": false,
      "description": "Indique si l'email a été vérifié."
    },

    "roles": {
      "type": "array",
      "description": "Rôles globaux éventuels (admin, etc.).",
      "items": { "type": "string" }
    },

    "preferences": {
      "type": "object",
      "description": "Préférences utilisateur (langue, thčme, etc.).",
      "properties": {
        "language": {
          "type": "string",
          "description": "Langue préférée (ex: 'fr', 'en')."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "system"],
          "default": "system"
        }
      },
      "additionalProperties": true
    },

    "dashboardLayout": {
      "type": "object",
      "description": "Configurations de layout de dashboard par rôle.",
      "properties": {
        "mj": {
          "type": "object",
          "description": "Layout du dashboard en tant que MJ.",
          "additionalProperties": true
        },
        "player": {
          "type": "object",
          "description": "Layout du dashboard en tant que joueur.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },

    "security": {
      "type": "object",
      "description": "Paramčtres de sécurité et 2FA.",
      "properties": {
        "hasTotp": {
          "type": "boolean",
          "default": false,
          "description": "Indique si une 2FA TOTP est activée."
        },
        "totpSecretStored": {
          "type": "boolean",
          "default": false,
          "description": "Indique côté modčle si un secret TOTP est enregistré (le secret lui-męme n'est pas exposé)."
        },
        "hasWebAuthn": {
          "type": "boolean",
          "default": false,
          "description": "Indique si au moins une clé WebAuthn/passkey est enregistrée."
        },
        "backupCodesCount": {
          "type": "number",
          "default": 0,
          "description": "Nombre de codes de secours actifs."
        },
        "lastPasswordChangeAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "lastLoginAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },

    "webauthnCredentials": {
      "type": "array",
      "description": "Liste des identifiants WebAuthn/passkeys enregistrés (côté serveur, données minimales).",
      "items": {
        "type": "object",
        "required": ["id", "name", "createdAt"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant de la credential WebAuthn (credential ID encodé)."
          },
          "name": {
            "type": "string",
            "description": "Nom convivial donné par l'utilisateur (ex: 'Laptop maison')."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastUsedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },

    "discord": {
      "type": ["object", "null"],
      "description": "Informations de liaison avec un compte Discord.",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID utilisateur Discord."
        },
        "username": {
          "type": "string",
          "description": "Nom d'utilisateur Discord."
        },
        "discriminator": {
          "type": "string",
          "description": "Discriminateur Discord (ex: '1234')."
        },
        "avatar": {
          "type": ["string", "null"],
          "description": "Hash ou URL de l'avatar Discord."
        },
        "linkedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date de liaison du compte Discord."
        }
      },
      "additionalProperties": false
    },

    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Date de création du compte."
    },

    "updatedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Derničre mise ŕ jour du profil."
    }
  },
  "additionalProperties": false
}
