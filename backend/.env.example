NODE_ENV=production
PORT=4000

# CORS frontend URL
CORS_ORIGIN=https://nexusforge.en-ligne.fr

# Public URLs used in email links
APP_BASE_URL=https://nexusforge.en-ligne.fr
API_BASE_URL=https://api.nexusforge.en-ligne.fr

# JWT (set long random secrets)
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Root admin (protected account)
ROOT_ADMIN_FIRST_NAME=Mikael
ROOT_ADMIN_LAST_NAME=Fremaux
ROOT_ADMIN_NICKNAME=IronmanLM
ROOT_ADMIN_EMAIL=ironmanlm@en-ligne.fr
ROOT_ADMIN_PASSWORD=change-me-root-admin-password

# Account lockout policy (after MAX_FAILED_ATTEMPTS: 15m, 30m, 1h)
MAX_FAILED_ATTEMPTS=5

# Token TTLs (milliseconds)
EMAIL_TOKEN_TTL_MS=86400000
RESET_TOKEN_TTL_MS=3600000
TWO_FACTOR_CHALLENGE_TTL_MS=300000

# SMTP (o2switch)
SMTP_HOST=mail.votre-domaine.tld
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@votre-domaine.tld
SMTP_PASS=change-me-smtp-password
SMTP_FROM="NexusForge <no-reply@votre-domaine.tld>"
