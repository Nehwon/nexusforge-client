{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusforge.app/schemas/system.schema.json",
  "title": "System",
  "type": "object",
  "required": ["id", "name", "version", "createdAt", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Identifiant unique du systËme (UUID)."
    },
    "name": {
      "type": "string",
      "description": "Nom du systËme (ex: 'Mon D20 gÈnÈrique')."
    },
    "slug": {
      "type": "string",
      "description": "Slug URL-friendly optionnel."
    },
    "description": {
      "type": "string",
      "description": "Description courte du systËme."
    },
    "version": {
      "type": "string",
      "description": "Version du systËme (ex: '0.1.0')."
    },
    "author": {
      "type": "string",
      "description": "Nom ou identifiant de l'auteur."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags (fantasy, SF, horreur, etc.)."
    },
    "visibility": {
      "type": "string",
      "enum": ["private", "shared", "public"],
      "default": "private",
      "description": "VisibilitÈ sur la plateforme (privÈ, partagÈ avec table, public)."
    },

    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },

    "settings": {
      "type": "object",
      "description": "ParamËtres globaux du systËme.",
      "properties": {
        "diceNotation": {
          "type": "string",
          "description": "Notation de dÈs par dÈfaut (ex: 'd20', '3d6')."
        },
        "hasHitPoints": {
          "type": "boolean",
          "default": true
        },
        "hasInitiative": {
          "type": "boolean",
          "default": true
        },
        "defaultLanguage": {
          "type": "string",
          "description": "Langue principale (ex: 'fr', 'en')."
        }
      },
      "additionalProperties": true
    },

    "attributes": {
      "type": "array",
      "description": "Liste des caractÈristiques de base (Force, Dex, etc.).",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant interne de l'attribut."
          },
          "name": {
            "type": "string",
            "description": "Nom affichÈ (ex: 'Force')."
          },
          "key": {
            "type": "string",
            "description": "ClÈ courte (ex: 'STR')."
          },
          "type": {
            "type": "string",
            "enum": ["number", "string", "boolean"],
            "default": "number"
          },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "default": { "type": ["number", "string", "boolean", "null"] },
          "formula": {
            "type": "string",
            "description": "Formule optionnelle (ex: 'floor((STR-10)/2)')."
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "resources": {
      "type": "array",
      "description": "Ressources (PV, mana, stress, etc.).",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "key": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["number", "gauge"],
            "default": "number"
          },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "default": { "type": "number" },
          "isHiddenFromPlayers": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },

    "skills": {
      "type": "array",
      "description": "CompÈtences, dons, etc.",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "key": { "type": "string" },
          "description": { "type": "string" },
          "linkedAttributeId": {
            "type": "string",
            "description": "RÈfÈrence ý un attribut (Force, Int, ...)."
          },
          "hasRank": {
            "type": "boolean",
            "default": true
          },
          "maxRank": { "type": "number" }
        }
      }
    },

    "characterTemplates": {
      "type": "array",
      "description": "Templates de fiches pour PJ, PNJ, monstres, etc.",
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["pc", "npc", "monster", "other"]
          },
          "layout": {
            "type": "object",
            "description": "Description de la mise en page (sections, groupes, champs).",
            "additionalProperties": true
          },
          "defaults": {
            "type": "object",
            "description": "Valeurs par dÈfaut pour les champs.",
            "additionalProperties": true
          }
        }
      }
    },

    "rollDefinitions": {
      "type": "array",
      "description": "Jets typiques (attaque, sauvegarde, compÈtence...).",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "key": { "type": "string" },
          "description": { "type": "string" },
          "dice": {
            "type": "string",
            "description": "Notation de dÈs (ex: '1d20', '3d6')."
          },
          "components": {
            "type": "array",
            "description": "Composants qui s'ajoutent au jet (attributs, compÈtences, bonus).",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["attribute", "skill", "resource", "constant", "script"]
                },
                "refId": {
                  "type": "string",
                  "description": "ID de l'attribut/compÈtence/ressource."
                },
                "value": {
                  "type": "number",
                  "description": "Valeur fixe pour 'constant'."
                },
                "scriptId": {
                  "type": "string",
                  "description": "RÈfÈrence ý un script de calcul (voir scripts)."
                }
              }
            }
          },
          "targetType": {
            "type": "string",
            "enum": ["fixed", "opposed", "none"],
            "default": "fixed"
          }
        }
      }
    },

    "scripts": {
      "type": "array",
      "description": "Scripts de rËgles (JS sandbox) ou blocs visuels sÈrialisÈs.",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["blockly", "javascript"]
          },
          "scope": {
            "type": "string",
            "enum": ["roll", "effect", "derivedStat", "hook"],
            "description": "Contexte d'exÈcution (jet, effet, stat dÈrivÈe, hook de vie)."
          },
          "blocklyJson": {
            "type": ["object", "null"],
            "description": "ReprÈsentation des blocs visuels (si kind = 'blockly').",
            "additionalProperties": true
          },
          "code": {
            "type": ["string", "null"],
            "description": "Code JS (si kind = 'javascript')."
          },
          "inputSchema": {
            "type": ["object", "null"],
            "description": "Description des donnÈes d'entrÈe (type-safe)."
          },
          "outputSchema": {
            "type": ["object", "null"],
            "description": "Description de la sortie attendue."
          }
        }
      }
    },

    "hooks": {
      "type": "array",
      "description": "Hooks du systËme (ÈvËnements du moteur).",
      "items": {
        "type": "object",
        "required": ["id", "event", "scriptId"],
        "properties": {
          "id": { "type": "string" },
          "event": {
            "type": "string",
            "description": "Nom d'ÈvËnement (ex: 'onAttackRoll', 'onLevelUp')."
          },
          "scriptId": {
            "type": "string",
            "description": "RÈfÈrence ý un script ý exÈcuter sur cet ÈvËnement."
          }
        }
      }
    }
  },
  "additionalProperties": false
}
